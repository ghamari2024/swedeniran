# swedeniran environment configuration
# Copy this file to ".env" and fill in your keys.

# Brave Search API (free tier: 2000 queries/month) -- recommended for
# reliable company website/LinkedIn discovery at scale.
# Get a key at: https://brave.com/search/api/
BRAVE_SEARCH_API_KEY=

# Alternative: SerpAPI (free tier: 100/month). Used only if Brave key is absent.
# SERPAPI_KEY=

# Cursor SDK (Node) — required for CRM campaign site generation (Composer agent).
# Run once: npm install
# Get a key at: https://cursor.com/dashboard/integrations
CURSOR_API_KEY=

# Optional: campaign agent model id (default composer-2)
# SWEDENIRAN_CAMPAIGN_MODEL=composer-2

# Titan / SMTP — CRM outbound email (enable Third-party email access in Titan)
# SMTP_HOST=smtp.titan.email
# SMTP_PORT=465
# SMTP_USER=you@yourdomain.com
# SMTP_PASSWORD=your-mailbox-password
# SMTP_FROM=you@yourdomain.com

# IMAP — reply/bounce polling (Titan: imap.titan.email port 993)
# IMAP_HOST=imap.titan.email
# IMAP_PORT=993

# Email marketing rate limits (conservative defaults)
# EMAIL_DAILY_LIMIT=40
# EMAIL_MIN_INTERVAL_SECONDS=90
# EMAIL_SEND_WINDOW=09:00-17:00
# Simulation — review inbox (toggle in campaign UI; default on). DB company emails unchanged.
# EMAIL_SIMULATION_TO=ghamari2004@gmail.com
# IMAP_POLL_SECONDS=300
# PUBLIC_BASE_URL=http://127.0.0.1:8787

# Optional tuning
# SWEDENIRAN_COMPANY_DEEP_WORKERS=1
# SWEDENIRAN_SEARCH_MIN_INTERVAL=3.5
